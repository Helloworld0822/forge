{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Forge",
  "scopeName": "source.forge",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.forge",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.forge",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.forge", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.forge",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.forge",
          "match": "\\b(process|coroutine|supervisor|spawn|send|recv|yield|await|if|else|while|for|break|continue|return|match|on|receive|restart)\\b"
        },
        {
          "name": "keyword.declaration.forge",
          "match": "\\b(let|mut|own|move|fn|const|struct|enum|native|extern|import|library|export)\\b"
        },
        {
          "name": "constant.language.forge",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.forge",
          "match": "\\b(int|float|bool|string|void|ptr)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.forge",
          "match": "(\\+=|-=|\\*=|/=|%=|=>|==|!=|<=|>=|&&|\\|\\||\\|>|\\.|::)"
        }
      ]
    }
  }
}
