// Forge self-hosted compiler — transpiles Forge subset to C.
// Stage0 (C forge) compiles this file → forge-stage1.
// Stage1 compiles this file again → forge-stage2 (self-host).

import strings;
import fs;
import os;

fn q(): string { return str_append("", 34); }
fn nl(): string { return str_append("", 10); }

fn is_ident(ch: int): int {
    if (ch >= 65 && ch <= 90) { return 1; }
    if (ch >= 97 && ch <= 122) { return 1; }
    if (ch >= 48 && ch <= 57) { return 1; }
    if (ch == 95) { return 1; }
    return 0;
}

fn skip_ws(src: string, i: int): int {
    while (i < str_len(src)) {
        let ch: int = str_char_at(src, i);
        if (ch == 32 || ch == 9 || ch == 10 || ch == 13) {
            i = i + 1;
            continue;
        }
        if (ch == 47 && str_char_at(src, i + 1) == 47) {
            while (i < str_len(src) && str_char_at(src, i) != 10) { i = i + 1; }
            continue;
        }
        break;
    }
    return i;
}

fn starts_at(src: string, i: int, kw: string): int {
    let k: int = str_len(kw);
    if (i + k > str_len(src)) { return 0; }
    return str_eq(str_sub(src, i, k), kw);
}

fn matching_brace(src: string, open: int): int {
    let depth: int = 0;
    let i: int = open;
    let in_str: int = 0;
    while (i < str_len(src)) {
        let ch: int = str_char_at(src, i);
        if (in_str == 1) {
            if (ch == 34) { in_str = 0; }
            i = i + 1;
            continue;
        }
        if (ch == 34) { in_str = 1; i = i + 1; continue; }
        if (ch == 123) { depth = depth + 1; }
        if (ch == 125) {
            depth = depth - 1;
            if (depth == 0) { return i; }
        }
        i = i + 1;
    }
    return -1;
}

fn matching_paren(src: string, open: int): int {
    let depth: int = 0;
    let i: int = open;
    let in_str: int = 0;
    while (i < str_len(src)) {
        let ch: int = str_char_at(src, i);
        if (in_str == 1) {
            if (ch == 34) { in_str = 0; }
            i = i + 1;
            continue;
        }
        if (ch == 34) { in_str = 1; i = i + 1; continue; }
        if (ch == 40) { depth = depth + 1; }
        if (ch == 41) {
            depth = depth - 1;
            if (depth == 0) { return i; }
        }
        i = i + 1;
    }
    return -1;
}

fn forge_ctype(ty: string): string {
    ty = str_trim(ty);
    if (str_eq(ty, "string")) { return "const char*"; }
    if (str_eq(ty, "int")) { return "int64_t"; }
    if (str_eq(ty, "void")) { return "void"; }
    return "int64_t";
}

fn map_ident(name: string): string {
    if (str_eq(name, "str_len")) { return "fr_str_len"; }
    if (str_eq(name, "str_concat")) { return "fr_str_concat"; }
    if (str_eq(name, "str_append")) { return "fr_str_append"; }
    if (str_eq(name, "str_append_str")) { return "fr_str_append_str"; }
    if (str_eq(name, "str_eq")) { return "fr_str_eq"; }
    if (str_eq(name, "str_sub")) { return "fr_str_sub"; }
    if (str_eq(name, "str_trim")) { return "fr_str_trim"; }
    if (str_eq(name, "str_contains")) { return "fr_str_contains"; }
    if (str_eq(name, "str_char_at")) { return "fr_str_char_at"; }
    if (str_eq(name, "str_reset_arena")) { return "fr_str_arena_reset"; }
    if (str_eq(name, "fs_read")) { return "fr_fs_read"; }
    if (str_eq(name, "fs_write")) { return "fr_fs_write"; }
    if (str_eq(name, "fs_append")) { return "fr_fs_append"; }
    if (str_eq(name, "fs_exists")) { return "fr_fs_exists"; }
    if (str_eq(name, "fs_remove")) { return "fr_fs_remove"; }
    if (str_eq(name, "fs_size")) { return "fr_fs_size"; }
    if (str_eq(name, "fs_is_file")) { return "fr_fs_is_file"; }
    if (str_eq(name, "fs_is_dir")) { return "fr_fs_is_dir"; }
    if (str_eq(name, "fs_mkdir")) { return "fr_fs_mkdir"; }
    if (str_eq(name, "fs_rename")) { return "fr_fs_rename"; }
    if (str_eq(name, "fs_copy")) { return "fr_fs_copy"; }
    if (str_eq(name, "fs_list_dir")) { return "fr_fs_list_dir"; }
    if (str_eq(name, "print")) { return "fr_print"; }
    if (str_eq(name, "print_int")) { return "fr_print_int"; }
    if (str_eq(name, "print_str")) { return "fr_print_str"; }
    if (str_eq(name, "eprint")) { return "fr_eprint"; }
    if (str_eq(name, "eprint_int")) { return "fr_io_eprint_int"; }
    if (str_eq(name, "eprintln")) { return "fr_eprintln"; }
    if (str_eq(name, "flush")) { return "fr_io_flush"; }
    if (str_eq(name, "flush_err")) { return "fr_io_flush_err"; }
    if (str_eq(name, "read_line")) { return "fr_io_read_line"; }
    if (str_eq(name, "read_char")) { return "fr_io_read_char"; }
    if (str_eq(name, "read_stdin")) { return "fr_io_read_stdin"; }
    if (str_eq(name, "prompt")) { return "fr_io_prompt"; }
    if (str_eq(name, "write_fd")) { return "fr_io_write_fd"; }
    if (str_eq(name, "read_fd")) { return "fr_io_read_fd"; }
    if (str_eq(name, "stdin_fd")) { return "fr_io_stdin_fd"; }
    if (str_eq(name, "stdout_fd")) { return "fr_io_stdout_fd"; }
    if (str_eq(name, "stderr_fd")) { return "fr_io_stderr_fd"; }
    if (str_eq(name, "os_argc")) { return "fr_os_argc"; }
    if (str_eq(name, "os_argv")) { return "fr_os_argv"; }
    if (str_eq(name, "os_exit")) { return "fr_os_exit"; }
    return name;
}

fn compile_expr(expr: string): string {
    let out: string = "";
    let i: int = 0;
    let n: int = str_len(expr);
    while (i < n) {
        let ch: int = str_char_at(expr, i);
        if (ch == 34) {
            let j: int = i + 1;
            while (j < n) {
                if (str_char_at(expr, j) == 34) { break; }
                j = j + 1;
            }
            out = str_append_str(out, str_sub(expr, i, j - i + 1));
            i = j + 1;
            continue;
        }
        if (is_ident(ch) == 1) {
            let j: int = i;
            while (j < n && is_ident(str_char_at(expr, j)) == 1) { j = j + 1; }
            let id: string = str_sub(expr, i, j - i);
            out = str_append_str(out, map_ident(id));
            i = j;
            continue;
        }
        out = str_append(out, ch);
        i = i + 1;
    }
    return out;
}

fn emit_header(src: string): string {
    let out: string = "// Generated by Forge self-hosted compiler";
    out = str_append_str(out, nl());
    out = str_append_str(out, "#include ");
    out = str_append_str(out, q());
    out = str_append_str(out, "forge_runtime.h");
    out = str_append_str(out, q());
    out = str_append_str(out, nl());
    out = str_append_str(out, "#include <stdio.h>");
    out = str_append_str(out, nl());
    out = str_append_str(out, "#include <stdlib.h>");
    out = str_append_str(out, nl());
    out = str_append_str(out, "#include <string.h>");
    out = str_append_str(out, nl());
    out = str_append_str(out, "#include ");
    out = str_append_str(out, q());
    out = str_append_str(out, "forge/os.h");
    out = str_append_str(out, q());
    out = str_append_str(out, nl());
    if (str_contains(src, "import strings")) {
        out = str_append_str(out, "#include ");
        out = str_append_str(out, q());
        out = str_append_str(out, "forge/string.h");
        out = str_append_str(out, q());
        out = str_append_str(out, nl());
    }
    if (str_contains(src, "import fs")) {
        out = str_append_str(out, "#include ");
        out = str_append_str(out, q());
        out = str_append_str(out, "forge/fs.h");
        out = str_append_str(out, q());
        out = str_append_str(out, nl());
    }
    if (str_contains(src, "import io")) {
        out = str_append_str(out, "#include ");
        out = str_append_str(out, q());
        out = str_append_str(out, "forge/io.h");
        out = str_append_str(out, q());
        out = str_append_str(out, nl());
    }
    if (str_contains(src, "import os")) {
        out = str_append_str(out, "#include ");
        out = str_append_str(out, q());
        out = str_append_str(out, "forge/os.h");
        out = str_append_str(out, q());
        out = str_append_str(out, nl());
    }
    out = str_append_str(out, nl());
    return out;
}

fn println_arg_is_string(arg: string): int {
    if (str_len(arg) == 0) { return 0; }
    if (str_char_at(arg, 0) == 34) { return 1; }
    if (starts_at(arg, 0, "fs_read(") == 1) { return 1; }
    if (starts_at(arg, 0, "fs_list_dir(") == 1) { return 1; }
    if (starts_at(arg, 0, "read_line(") == 1) { return 1; }
    if (starts_at(arg, 0, "read_stdin(") == 1) { return 1; }
    if (starts_at(arg, 0, "prompt(") == 1) { return 1; }
    if (starts_at(arg, 0, "read_fd(") == 1) { return 1; }
    if (starts_at(arg, 0, "str_concat(") == 1) { return 1; }
    if (starts_at(arg, 0, "str_") == 1) { return 1; }
    if (starts_at(arg, 0, "os_argv(") == 1) { return 1; }
    return 0;
}

fn emit_println_stmt(line: string): string {
    let start: int = 0;
    let i: int = 0;
    while (i < str_len(line)) {
        if (str_char_at(line, i) == 40) { start = i + 1; break; }
        i = i + 1;
    }
    let end: int = str_len(line) - 1;
    while (end > start) {
        if (str_char_at(line, end) == 41) { break; }
        end = end - 1;
    }
    let arg: string = str_trim(str_sub(line, start, end - start));
    if (str_len(arg) == 0) {
        let empty_out: string = "    fr_println();";
        empty_out = str_append_str(empty_out, nl());
        return empty_out;
    }
    let out: string = "    ({ ";
    if (println_arg_is_string(arg) == 1) {
        out = str_append_str(out, "fr_print_str(");
        if (str_char_at(arg, 0) == 34) {
            out = str_append_str(out, arg);
        } else {
            out = str_append_str(out, compile_expr(arg));
        }
        out = str_append_str(out, "); fr_println(); });");
    } else {
        out = str_append_str(out, "fr_print_int(");
        out = str_append_str(out, compile_expr(arg));
        out = str_append_str(out, "); fr_println(); });");
    }
    out = str_append_str(out, nl());
    return out;
}

fn compile_match_arm(line: string): string {
    let out: string = "";
    let arrow: int = -1;
    let i: int = 0;
    while (i < str_len(line) - 1) {
        if (str_char_at(line, i) == 61 && str_char_at(line, i + 1) == 62) {
            arrow = i;
            break;
        }
        i = i + 1;
    }
    if (arrow < 0) { return ""; }
    let pat: string = str_trim(str_sub(line, 0, arrow));
    let rest: string = str_trim(str_sub(line, arrow + 2, str_len(line) - arrow - 2));
    let body: string = rest;
    if (str_len(rest) > 0 && str_char_at(rest, 0) == 123) {
        let b1: int = matching_brace(rest, 0);
        if (b1 > 0) {
            body = str_trim(str_sub(rest, 1, b1 - 1));
        }
    }
    if (str_eq(pat, "_")) {
        out = str_append_str(out, "    } else {");
    } else {
        out = str_append_str(out, "    } else if (__match_val == ");
        out = str_append_str(out, compile_expr(pat));
        out = str_append_str(out, ") {");
    }
    out = str_append_str(out, nl());
    if (starts_at(body, 0, "println(") == 1) {
        out = str_append_str(out, emit_println_stmt(body));
    } else if (str_len(body) > 0) {
        out = str_append_str(out, compile_block(body, 0, str_len(body)));
    }
    return out;
}

fn find_stmt_end(src: string, start: int, end: int): int {
    let semi: int = start;
    let depth: int = 0;
    let in_str: int = 0;
    while (semi < end) {
        let ch: int = str_char_at(src, semi);
        if (in_str == 1) {
            if (ch == 34) { in_str = 0; }
            semi = semi + 1;
            continue;
        }
        if (ch == 34) { in_str = 1; semi = semi + 1; continue; }
        if (ch == 40) { depth = depth + 1; }
        if (ch == 41) { depth = depth - 1; }
        if (ch == 59 && depth == 0) { return semi; }
        semi = semi + 1;
    }
    return end;
}

fn find_semi_at(src: string, start: int, end: int): int {
    let semi: int = start;
    let depth: int = 0;
    let in_str: int = 0;
    while (semi < end) {
        let ch: int = str_char_at(src, semi);
        if (in_str == 1) {
            if (ch == 34) { in_str = 0; }
            semi = semi + 1;
            continue;
        }
        if (ch == 34) { in_str = 1; semi = semi + 1; continue; }
        if (ch == 40) { depth = depth + 1; }
        if (ch == 41) { depth = depth - 1; }
        if (ch == 59 && depth == 0) { return semi; }
        semi = semi + 1;
    }
    return -1;
}

fn compile_inline_stmt(stmt: string): string {
    let out: string = "";
    stmt = str_trim(stmt);
    if (str_len(stmt) == 0) { return ""; }
    if (starts_at(stmt, 0, "let ") == 1) {
        let body: string = str_trim(str_sub(stmt, 4, str_len(stmt) - 4));
        let eq: int = 0;
        let j: int = 0;
        while (j < str_len(body)) {
            if (str_char_at(body, j) == 61) { eq = j; break; }
            j = j + 1;
        }
        if (eq > 0) {
            let lhs: string = str_trim(str_sub(body, 0, eq));
            let rhs: string = str_trim(str_sub(body, eq + 1, str_len(body) - eq - 1));
            let colon: int = 0;
            let k: int = 0;
            while (k < str_len(lhs)) {
                if (str_char_at(lhs, k) == 58) { colon = k; break; }
                k = k + 1;
            }
            let name: string = str_trim(str_sub(lhs, 0, colon));
            let ty: string = "int";
            if (colon > 0) {
                ty = str_trim(str_sub(lhs, colon + 1, str_len(lhs) - colon - 1));
            }
            out = str_append_str(out, "        ");
            out = str_append_str(out, forge_ctype(ty));
            out = str_append_str(out, " ");
            out = str_append_str(out, name);
            out = str_append_str(out, " = ");
            out = str_append_str(out, compile_expr(rhs));
            out = str_append_str(out, ";");
            out = str_append_str(out, nl());
        }
        return out;
    }
    let eq: int = 0;
    let j: int = 0;
    while (j < str_len(stmt)) {
        if (str_char_at(stmt, j) == 61) { eq = j; break; }
        j = j + 1;
    }
    if (eq > 0 && is_ident(str_char_at(stmt, 0)) == 1) {
        let lhs: string = str_trim(str_sub(stmt, 0, eq));
        let rhs: string = str_trim(str_sub(stmt, eq + 1, str_len(stmt) - eq - 1));
        out = str_append_str(out, "        ");
        out = str_append_str(out, lhs);
        out = str_append_str(out, " = ");
        out = str_append_str(out, compile_expr(rhs));
        out = str_append_str(out, ";");
        out = str_append_str(out, nl());
    } else {
        out = str_append_str(out, "        ");
        out = str_append_str(out, compile_expr(stmt));
        out = str_append_str(out, ";");
        out = str_append_str(out, nl());
    }
    return out;
}

fn compile_block(src: string, start: int, end: int): string {
    let out: string = "";
    let i: int = start;
    while (i < end) {
        i = skip_ws(src, i);
        if (i >= end) { break; }

        if (starts_at(src, i, "let ") == 1) {
            i = i + 4;
            let semi: int = find_stmt_end(src, i, end);
            let stmt: string = str_trim(str_sub(src, i, semi - i));
            let eq: int = 0;
            let j: int = 0;
            while (j < str_len(stmt)) {
                if (str_char_at(stmt, j) == 61) { eq = j; break; }
                j = j + 1;
            }
            if (eq > 0) {
                let lhs: string = str_trim(str_sub(stmt, 0, eq));
                let rhs: string = str_trim(str_sub(stmt, eq + 1, str_len(stmt) - eq - 1));
                let colon: int = 0;
                let k: int = 0;
                while (k < str_len(lhs)) {
                    if (str_char_at(lhs, k) == 58) { colon = k; break; }
                    k = k + 1;
                }
                let name: string = str_trim(str_sub(lhs, 0, colon));
                let ty: string = "int";
                if (colon > 0) {
                    ty = str_trim(str_sub(lhs, colon + 1, str_len(lhs) - colon - 1));
                }
                out = str_append_str(out, "    ");
                out = str_append_str(out, forge_ctype(ty));
                out = str_append_str(out, " ");
                out = str_append_str(out, name);
                out = str_append_str(out, " = ");
                out = str_append_str(out, compile_expr(rhs));
                out = str_append_str(out, ";");
                out = str_append_str(out, nl());
            }
            i = semi + 1;
            continue;
        }

        if (starts_at(src, i, "if ") == 1) {
            i = i + 3;
            let p0: int = i;
            while (p0 < end && str_char_at(src, p0) != 40) { p0 = p0 + 1; }
            let p1: int = matching_paren(src, p0);
            let cond: string = str_trim(str_sub(src, p0 + 1, p1 - p0 - 1));
            let b0: int = p1 + 1;
            while (b0 < end && str_char_at(src, b0) != 123) { b0 = b0 + 1; }
            let b1: int = matching_brace(src, b0);
            out = str_append_str(out, "    if (");
            out = str_append_str(out, compile_expr(cond));
            out = str_append_str(out, ") {");
            out = str_append_str(out, nl());
            out = str_append_str(out, compile_block(src, b0 + 1, b1));
            out = str_append_str(out, "    }");
            out = str_append_str(out, nl());
            i = b1 + 1;
            i = skip_ws(src, i);
            while (starts_at(src, i, "else") == 1) {
                i = i + 4;
                i = skip_ws(src, i);
                if (starts_at(src, i, "if ") == 1) {
                    i = i + 3;
                    let ep0: int = i;
                    while (ep0 < end && str_char_at(src, ep0) != 40) { ep0 = ep0 + 1; }
                    let ep1: int = matching_paren(src, ep0);
                    let econd: string = str_trim(str_sub(src, ep0 + 1, ep1 - ep0 - 1));
                    let eb0: int = ep1 + 1;
                    while (eb0 < end && str_char_at(src, eb0) != 123) { eb0 = eb0 + 1; }
                    let eb1: int = matching_brace(src, eb0);
                    out = str_append_str(out, "    else if (");
                    out = str_append_str(out, compile_expr(econd));
                    out = str_append_str(out, ") {");
                    out = str_append_str(out, nl());
                    out = str_append_str(out, compile_block(src, eb0 + 1, eb1));
                    out = str_append_str(out, "    }");
                    out = str_append_str(out, nl());
                    i = eb1 + 1;
                    i = skip_ws(src, i);
                } else {
                    while (i < end && str_char_at(src, i) != 123) { i = i + 1; }
                    let e1: int = matching_brace(src, i);
                    out = str_append_str(out, "    else {");
                    out = str_append_str(out, nl());
                    out = str_append_str(out, compile_block(src, i + 1, e1));
                    out = str_append_str(out, "    }");
                    out = str_append_str(out, nl());
                    i = e1 + 1;
                    break;
                }
            }
            continue;
        }

        if (starts_at(src, i, "for (") == 1) {
            i = i + 4;
            let p0: int = i;
            let p1: int = matching_paren(src, p0);
            let semi1: int = find_semi_at(src, p0 + 1, p1);
            let semi2: int = find_semi_at(src, semi1 + 1, p1);
            let init: string = str_trim(str_sub(src, p0 + 1, semi1 - p0 - 1));
            let cond: string = str_trim(str_sub(src, semi1 + 1, semi2 - semi1 - 1));
            let step: string = str_trim(str_sub(src, semi2 + 1, p1 - semi2 - 1));
            let b0: int = p1 + 1;
            while (b0 < end && str_char_at(src, b0) != 123) { b0 = b0 + 1; }
            let b1: int = matching_brace(src, b0);
            out = str_append_str(out, "    {");
            out = str_append_str(out, nl());
            if (str_len(init) > 0) {
                out = str_append_str(out, compile_inline_stmt(init));
            }
            out = str_append_str(out, "        while (");
            out = str_append_str(out, compile_expr(cond));
            out = str_append_str(out, ") {");
            out = str_append_str(out, nl());
            out = str_append_str(out, compile_block(src, b0 + 1, b1));
            if (str_len(step) > 0) {
                out = str_append_str(out, compile_inline_stmt(step));
            }
            out = str_append_str(out, "        }");
            out = str_append_str(out, nl());
            out = str_append_str(out, "    }");
            out = str_append_str(out, nl());
            i = b1 + 1;
            continue;
        }

        if (starts_at(src, i, "while ") == 1) {
            i = i + 6;
            let p0: int = i;
            while (p0 < end && str_char_at(src, p0) != 40) { p0 = p0 + 1; }
            let p1: int = matching_paren(src, p0);
            let cond: string = str_trim(str_sub(src, p0 + 1, p1 - p0 - 1));
            let b0: int = p1 + 1;
            while (b0 < end && str_char_at(src, b0) != 123) { b0 = b0 + 1; }
            let b1: int = matching_brace(src, b0);
            out = str_append_str(out, "    while (");
            out = str_append_str(out, compile_expr(cond));
            out = str_append_str(out, ") {");
            out = str_append_str(out, nl());
            out = str_append_str(out, compile_block(src, b0 + 1, b1));
            out = str_append_str(out, "    }");
            out = str_append_str(out, nl());
            i = b1 + 1;
            continue;
        }

        if (starts_at(src, i, "return") == 1) {
            i = i + 6;
            let semi: int = find_stmt_end(src, i, end);
            let val: string = str_trim(str_sub(src, i, semi - i));
            out = str_append_str(out, "    return ");
            out = str_append_str(out, compile_expr(val));
            out = str_append_str(out, ";");
            out = str_append_str(out, nl());
            i = semi + 1;
            continue;
        }

        if (starts_at(src, i, "break") == 1) {
            out = str_append_str(out, "    break;");
            out = str_append_str(out, nl());
            while (i < end && str_char_at(src, i) != 59) { i = i + 1; }
            i = i + 1;
            continue;
        }

        if (starts_at(src, i, "continue") == 1) {
            out = str_append_str(out, "    continue;");
            out = str_append_str(out, nl());
            while (i < end && str_char_at(src, i) != 59) { i = i + 1; }
            i = i + 1;
            continue;
        }

        if (starts_at(src, i, "match ") == 1) {
            i = i + 6;
            let scr_end: int = i;
            while (scr_end < end && str_char_at(src, scr_end) != 123) { scr_end = scr_end + 1; }
            let scr: string = str_trim(str_sub(src, i, scr_end - i));
            let b0: int = scr_end;
            let b1: int = matching_brace(src, b0);
            out = str_append_str(out, "    { int64_t __match_val = ");
            out = str_append_str(out, compile_expr(scr));
            out = str_append_str(out, ";");
            out = str_append_str(out, nl());
            out = str_append_str(out, "    if (0) {");
            out = str_append_str(out, nl());
            let mi: int = b0 + 1;
            while (mi < b1) {
                mi = skip_ws(src, mi);
                if (mi >= b1) { break; }
                let line_end: int = mi;
                while (line_end < b1 && str_char_at(src, line_end) != 10) { line_end = line_end + 1; }
                let mline: string = str_trim(str_sub(src, mi, line_end - mi));
                if (str_contains(mline, "=>")) {
                    out = str_append_str(out, compile_match_arm(mline));
                }
                mi = line_end + 1;
            }
            out = str_append_str(out, "    }");
            out = str_append_str(out, nl());
            out = str_append_str(out, "    }");
            out = str_append_str(out, nl());
            i = b1 + 1;
            continue;
        }

        let line_end: int = i;
        while (line_end < end && str_char_at(src, line_end) != 10) { line_end = line_end + 1; }
        let line: string = str_trim(str_sub(src, i, line_end - i));
        if (starts_at(line, 0, "println(") == 1) {
            out = str_append_str(out, emit_println_stmt(line));
            i = line_end + 1;
            continue;
        }

        let semi: int = find_stmt_end(src, i, end);
        let stmt: string = str_trim(str_sub(src, i, semi - i));
        if (str_len(stmt) > 0) {
            let eq: int = 0;
            let j: int = 0;
            while (j < str_len(stmt)) {
                if (str_char_at(stmt, j) == 61) { eq = j; break; }
                j = j + 1;
            }
            if (eq > 0 && is_ident(str_char_at(stmt, 0)) == 1) {
                let lhs: string = str_trim(str_sub(stmt, 0, eq));
                let rhs: string = str_trim(str_sub(stmt, eq + 1, str_len(stmt) - eq - 1));
                out = str_append_str(out, "    ");
                out = str_append_str(out, lhs);
                out = str_append_str(out, " = ");
                out = str_append_str(out, compile_expr(rhs));
                out = str_append_str(out, ";");
                out = str_append_str(out, nl());
            } else {
                out = str_append_str(out, "    ");
                out = str_append_str(out, compile_expr(stmt));
                out = str_append_str(out, ";");
                out = str_append_str(out, nl());
            }
        }
        i = semi + 1;
    }
    return out;
}

fn compile_params(params: string): string {
    let out: string = "";
    let i: int = 0;
    let first: int = 1;
    while (i < str_len(params)) {
        i = skip_ws(params, i);
        if (i >= str_len(params)) { break; }
        let j: int = i;
        while (j < str_len(params) && str_char_at(params, j) != 44) { j = j + 1; }
        let part: string = str_trim(str_sub(params, i, j - i));
        let colon: int = 0;
        let k: int = 0;
        while (k < str_len(part)) {
            if (str_char_at(part, k) == 58) { colon = k; break; }
            k = k + 1;
        }
        if (colon > 0) {
            let pname: string = str_trim(str_sub(part, 0, colon));
            let pty: string = str_trim(str_sub(part, colon + 1, str_len(part) - colon - 1));
            if (first == 0) { out = str_append_str(out, ", "); }
            out = str_append_str(out, forge_ctype(pty));
            out = str_append_str(out, " ");
            out = str_append_str(out, pname);
            first = 0;
        }
        i = j + 1;
    }
    return out;
}

fn compile_fn_decl(name: string, params: string, ret: string): string {
    let out: string = "static ";
    out = str_append_str(out, forge_ctype(ret));
    out = str_append_str(out, " ");
    out = str_append_str(out, name);
    out = str_append_str(out, "(");
    out = str_append_str(out, compile_params(params));
    out = str_append_str(out, ");");
    out = str_append_str(out, nl());
    return out;
}

fn compile_fn_def(name: string, params: string, ret: string, body: string): string {
    let out: string = "static ";
    out = str_append_str(out, forge_ctype(ret));
    out = str_append_str(out, " ");
    out = str_append_str(out, name);
    out = str_append_str(out, "(");
    out = str_append_str(out, compile_params(params));
    out = str_append_str(out, ") {");
    out = str_append_str(out, nl());
    out = str_append_str(out, compile_block(body, 0, str_len(body)));
    if (str_eq(ret, "void") == 0 && str_contains(body, "return") == 0) {
        if (str_eq(ret, "string")) {
            out = str_append_str(out, "    return ");
            out = str_append_str(out, q());
            out = str_append_str(out, q());
            out = str_append_str(out, ";");
        } else {
            out = str_append_str(out, "    return 0;");
        }
        out = str_append_str(out, nl());
    }
    out = str_append_str(out, "}");
    out = str_append_str(out, nl());
    out = str_append_str(out, nl());
    return out;
}

fn compile_consts(src: string): string {
    let out: string = "";
    let i: int = 0;
    let in_str: int = 0;
    while (i < str_len(src)) {
        let ch: int = str_char_at(src, i);
        if (in_str == 1) {
            if (ch == 34) { in_str = 0; }
            i = i + 1;
            continue;
        }
        if (ch == 34) { in_str = 1; i = i + 1; continue; }
        if ((i == 0 || str_char_at(src, i - 1) == 10) && starts_at(src, i, "const ") == 1) {
            let j: int = i + 6;
            let semi: int = j;
            while (semi < str_len(src) && str_char_at(src, semi) != 59) { semi = semi + 1; }
            let line: string = str_trim(str_sub(src, j, semi - j));
            let eq: int = 0;
            let k: int = 0;
            while (k < str_len(line)) {
                if (str_char_at(line, k) == 61) { eq = k; break; }
                k = k + 1;
            }
            if (eq > 0) {
                let name: string = str_trim(str_sub(line, 0, eq));
                let val: string = str_trim(str_sub(line, eq + 1, str_len(line) - eq - 1));
                out = str_append_str(out, "#define ");
                out = str_append_str(out, name);
                out = str_append_str(out, " ");
                out = str_append_str(out, val);
                out = str_append_str(out, nl());
            }
            i = semi + 1;
            continue;
        }
        i = i + 1;
    }
    return out;
}

fn find_block_after_keyword(src: string, keyword: string): string {
    let klen: int = str_len(keyword);
    let i: int = 0;
    let in_str: int = 0;
    while (i < str_len(src) - klen) {
        let ch: int = str_char_at(src, i);
        if (in_str == 1) {
            if (ch == 34) { in_str = 0; }
            i = i + 1;
            continue;
        }
        if (ch == 34) { in_str = 1; i = i + 1; continue; }
        if (str_eq(str_sub(src, i, klen), keyword)) {
            let next: int = str_char_at(src, i + klen);
            if (next == 32 || next == 123) {
                let j: int = i + klen;
                while (j < str_len(src)) {
                    if (str_char_at(src, j) == 123) {
                        let end: int = matching_brace(src, j);
                        if (end > 0) {
                            return str_sub(src, j + 1, end - j - 1);
                        }
                    }
                    j = j + 1;
                }
            }
        }
        i = i + 1;
    }
    return "";
}

fn compile_functions_to(src: string, path: string): int {
    let i: int = 0;
    let in_str: int = 0;
    while (i < str_len(src)) {
        let ch: int = str_char_at(src, i);
        if (in_str == 1) {
            if (ch == 34) { in_str = 0; }
            i = i + 1;
            continue;
        }
        if (ch == 34) { in_str = 1; i = i + 1; continue; }
        if ((i == 0 || str_char_at(src, i - 1) == 10) && starts_at(src, i, "fn ") == 1) {
            i = i + 3;
            let name_start: int = i;
            while (i < str_len(src) && str_char_at(src, i) != 40) { i = i + 1; }
            let name: string = str_trim(str_sub(src, name_start, i - name_start));
            let p1: int = matching_paren(src, i);
            let params: string = str_sub(src, i + 1, p1 - i - 1);
            let colon: int = p1 + 1;
            while (colon < str_len(src) && str_char_at(src, colon) != 58) { colon = colon + 1; }
            let ret_start: int = colon + 1;
            let b0: int = ret_start;
            while (b0 < str_len(src) && str_char_at(src, b0) != 123) { b0 = b0 + 1; }
            let ret: string = str_trim(str_sub(src, ret_start, b0 - ret_start));
            let b1: int = matching_brace(src, b0);
            fs_append(path, compile_fn_decl(name, params, ret));
            i = b1 + 1;
            continue;
        }
        i = i + 1;
    }
    fs_append(path, nl());
    i = 0;
    in_str = 0;
    while (i < str_len(src)) {
        let ch: int = str_char_at(src, i);
        if (in_str == 1) {
            if (ch == 34) { in_str = 0; }
            i = i + 1;
            continue;
        }
        if (ch == 34) { in_str = 1; i = i + 1; continue; }
        if ((i == 0 || str_char_at(src, i - 1) == 10) && starts_at(src, i, "fn ") == 1) {
            i = i + 3;
            let name_start: int = i;
            while (i < str_len(src) && str_char_at(src, i) != 40) { i = i + 1; }
            let name: string = str_trim(str_sub(src, name_start, i - name_start));
            let p1: int = matching_paren(src, i);
            let params: string = str_sub(src, i + 1, p1 - i - 1);
            let colon: int = p1 + 1;
            while (colon < str_len(src) && str_char_at(src, colon) != 58) { colon = colon + 1; }
            let ret_start: int = colon + 1;
            let b0: int = ret_start;
            while (b0 < str_len(src) && str_char_at(src, b0) != 123) { b0 = b0 + 1; }
            let ret: string = str_trim(str_sub(src, ret_start, b0 - ret_start));
            let b1: int = matching_brace(src, b0);
            let body: string = str_sub(src, b0 + 1, b1 - b0 - 1);
            fs_append(path, compile_fn_def(name, params, ret, body));
            i = b1 + 1;
            continue;
        }
        i = i + 1;
    }
    return 1;
}

fn compile_source_to(path: string, src: string): int {
    str_reset_arena();
    fs_write(path, emit_header(src));
    fs_append(path, compile_consts(src));
    compile_functions_to(src, path);
    let native_body: string = find_block_after_keyword(src, "native main");
    let process_body: string = find_block_after_keyword(src, "process main");

    if (str_len(native_body) > 0) {
        let init: string = compile_block(native_body, 0, str_len(native_body));
        let tail: string = "";
        tail = str_append_str(tail, "int main(int argc, char **argv) {");
        tail = str_append_str(tail, nl());
        tail = str_append_str(tail, "    fr_os_set_args(argc, argv);");
        tail = str_append_str(tail, nl());
        tail = str_append_str(tail, init);
        tail = str_append_str(tail, "    return 0;");
        tail = str_append_str(tail, nl());
        tail = str_append_str(tail, "}");
        tail = str_append_str(tail, nl());
        fs_append(path, tail);
        return 1;
    }

    if (str_len(process_body) == 0) {
        fs_append(path, "int main(void) { return 0; }");
        fs_append(path, nl());
        return 1;
    }

    let init: string = compile_block(process_body, 0, str_len(process_body));
    let tail: string = "";
    tail = str_append_str(tail, "static void main_init(fr_process_t *proc) {");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "    (void)proc;");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, init);
    tail = str_append_str(tail, "}");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "int main(int argc, char **argv) {");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "    fr_os_set_args(argc, argv);");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "    fr_scheduler_t *sched = fr_scheduler_create(1);");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "    fr_process_t *proc_main = fr_process_create(");
    tail = str_append_str(tail, q());
    tail = str_append_str(tail, "main");
    tail = str_append_str(tail, q());
    tail = str_append_str(tail, ");");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "    fr_scheduler_add_process(sched, proc_main);");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "    main_init(proc_main);");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "    fr_scheduler_run(sched);");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "    fr_scheduler_destroy(sched);");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "    return 0;");
    tail = str_append_str(tail, nl());
    tail = str_append_str(tail, "}");
    tail = str_append_str(tail, nl());
    fs_append(path, tail);
    return 1;
}

native main {
    if (os_argc() < 4) {
        println("Usage: compiler <input.fg> -o <output.c>");
        os_exit(1);
    }
    let input: string = os_argv(1);
    let output: string = os_argv(3);
    let src: string = fs_read(input);
    compile_source_to(output, src);
    println("compiled");
}
